{
  "name": "Cahaya Hospitality Lead Generation",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const leads = $json.data || [];\n\n// Sort oldest -> newest\nleads.sort((a, b) => {\n  return new Date(a.created_time) - new Date(b.created_time);\n});\n\nreturn leads.map((lead) => {\n\n  const fields = lead.field_data || [];\n\n  const getValue = (fieldName) => {\n    const field = fields.find(f => f.name === fieldName);\n    return field?.values?.[0] || \"\";\n  };\n\n  // Evolution API format = 91XXXXXXXXXX\n  const formatPhone = (phone) => {\n\n    if (!phone) return \"\";\n\n    const cleaned = phone.toString().replace(/\\D/g, \"\");\n\n    // 10 digit Indian number\n    if (cleaned.length === 10) {\n      return `91${cleaned}`;\n    }\n\n    // Already has 91 prefix\n    if (cleaned.length === 12 && cleaned.startsWith(\"91\")) {\n      return cleaned;\n    }\n\n    return cleaned;\n  };\n\n  const createdDate = new Date(lead.created_time);\n\n  const leadCreationDate = createdDate.toLocaleDateString(\"en-GB\");\n\n  // Follow-up Date (+2 days)\n  const followUp = new Date(createdDate);\n  followUp.setDate(followUp.getDate() + 2);\n\n  const followUpDate = followUp.toLocaleDateString(\"en-GB\");\n\n  return {\n    json: {\n\n      \"Lead ID\": String(lead.id),\n\n      \"Full Name\": getValue(\"full_name\"),\n\n      \"Contact\": formatPhone(\n        getValue(\"phone\")\n      ),\n\n      \"City\": getValue(\"city\"),\n\n      \"Check-in Date\": getValue(\"what_is_your_check-in_date?_(e.g._20_jun)\"),\n\n      \"Lead Creation Date\": leadCreationDate,\n\n      \"Follow-up Date\": followUpDate\n\n    }\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        16
      ],
