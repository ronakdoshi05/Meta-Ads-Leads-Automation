        "jsCode": "const existingLeadIds = $('List of Lead IDs')\n  .first()\n  .json\n  .leadIds || [];\n\nreturn $input\n  .all()\n  .filter(item => item.json[\"Lead ID\"]) // Ignore helper object\n  .map(item => {\n\n    const leadId = String(item.json[\"Lead ID\"]);\n\n    return {\n      json: {\n        ...item.json,\n        alreadyExists: existingLeadIds.includes(leadId)\n      }\n    };\n\n  });"
